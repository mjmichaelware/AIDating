rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own profile data
    // Requires authentication and the document ID to match the user's UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read 'matches' (e.g., suggested matches)
    // No write access for general users here, matches are likely generated by backend
    match /matches/{matchId} {
      allow read: if request.auth != null;
    }

    // Deny access to any other collection by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}