{
      "name": "Python App",
        "image": "mcr.microsoft.com/devcontainers/python:0-3.11", // Or your preferred Python image
          "features": {
              "ghcr.io/devcontainers/features/python:1": {}
                },
                  "postCreateCommand": "pip install --no-cache-dir -r backend/requirements.txt", // Adjust this path if your requirements.txt is elsewhere
                    "customizations": {
                        "vscode": {
                              "extensions": [
                                      "ms-python.python",
                                              "ms-vscode.vscode-typescript-next",
                                                      "ms-python.vscode-pylance"
                                                            ]
                                                                }
                                                                  }
                                                                  }
