@app.route('/login', methods=['POST'])
def login_user():
    """
    Handles user login.
    Expects JSON with 'username' and 'password'.
    Returns user's 'name' and a JWT if successful.
    """
    data = request.json
    username = data.get('username')
    password = data.get('password')

    if not username or not password:
        return jsonify({"error": "Username and password are required"}), 400

    user_ref = db.collection('users').document(username)
    user_doc = user_ref.get()

    if user_doc.exists:
        user_data = user_doc.to_dict()
        # In a real app: VERIFY HASHED PASSWORD (e.g., with Flask-Bcrypt)
        # For this dummy example, we compare plain passwords (INSECURE FOR REAL APP!)
        if user_data.get('password') == password:
            # Generate JWT
            payload = {
                'user_id': username,
                'display_name': user_data.get('name', username),
                'role': user_data.get('role', 'user'), # Example: add a role to token
                'exp': datetime.datetime.utcnow() + datetime.timedelta(hours=1) # Token expires in 1 hour
            }
            token = jwt.encode(payload, JWT_SECRET_KEY, algorithm='HS256')

            return jsonify({
                "message": "Login successful",
                "user_id": username,
                "display_name": user_data.get('name', username),
                "token": token
            }), 200
        else:
            return jsonify({"error": "Invalid password"}), 401
    else:
        return jsonify({"error": "User not found"}), 404

