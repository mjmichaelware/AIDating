enum Gender { male, female, other, unspecified }
enum EducationLevel { highSchool, bachelor, master, phd, other, unspecified }
enum HeightUnit { cm, feetInches }

class UserProfile {
  final String uid;
  final String username;
  final String email;
  final int? age;
  final Gender? gender;
  final Gender? seekingGender;
  final List<String>? hobbies;
  final String? bio;
  final EducationLevel? educationLevel;
  final int? heightCm;
  final String? pronouns;
  final String? profileStatus;

  UserProfile({required this.uid, required this.username, required this.email, this.age, this.gender, this.seekingGender, this.hobbies, this.bio, this.educationLevel, this.heightCm, this.pronouns, this.profileStatus});
  factory UserProfile.fromJson(Map<String, dynamic> json) {
    return UserProfile(
      uid: json['uid'] as String, username: json['username'] as String, email: json['email'] as String, age: json['age'] as int?,
      gender: _stringToGender(json['gender'] as String?), seekingGender: _stringToGender(json['seeking_gender'] as String?),
      hobbies: (json['hobbies'] as List<dynamic>?)?.map((e) => e as String).toList(), bio: json['bio'] as String?,
      educationLevel: _stringToEducationLevel(json['education_level'] as String?), heightCm: json['height_cm'] as int?, pronouns: json['pronouns'] as String?,
      profileStatus: json['profile_status'] as String?,
    );
  }
  Map<String, dynamic> toJson() {
    return {'uid': uid, 'username': username, 'email': email, 'age': age, 'gender': gender?.name, 'seeking_gender': seekingGender?.name,
      'hobbies': hobbies, 'bio': bio, 'education_level': educationLevel?.name, 'height_cm': heightCm, 'pronouns': pronouns,
      'profile_status': profileStatus};
  }
  static Gender? _stringToGender(String? gs) { if (gs == null) return null; try { return Gender.values.firstWhere((e) => e.name == gs.toLowerCase()); } catch (e) { return Gender.unspecified; }}
  static EducationLevel? _stringToEducationLevel(String? es) { if (es == null) return null; try { return EducationLevel.values.firstWhere((e) => e.name == es.toLowerCase()); } catch (e) { return EducationLevel.unspecified; }}
  UserProfile copyWith({String? uid, String? username, String? email, int? age, Gender? gender, Gender? seekingGender, List<String>? hobbies, String? bio, EducationLevel? educationLevel, int? heightCm, String? pronouns, String? profileStatus}) {
    return UserProfile(uid: uid ?? this.uid, username: username ?? this.username, email: email ?? this.email, age: age ?? this.age, gender: gender ?? this.gender, seekingGender: seekingGender ?? this.seekingGender, hobbies: hobbies ?? this.hobbies, bio: bio ?? this.bio, educationLevel: educationLevel ?? this.educationLevel, heightCm: heightCm ?? this.heightCm, pronouns: pronouns ?? this.pronouns, profileStatus: profileStatus ?? this.profileStatus);
  }
}

