@app.get("/users/me/profile", response_model=UserProfile)
async def get_current_user_profile(uid: str = Depends(get_current_user_uid)):
    profile_doc = await db.collection('user_profiles').document(uid).get()
    if not profile_doc.exists:
        raise HTTPException(status.HTTP_404_NOT_FOUND, detail="User profile not found. Please complete your questionnaire.")
    return UserProfile(**profile_doc.to_dict())

@app.put("/users/me/profile", response_model=UserProfile)
async def update_user_profile(profile_update: UserProfileUpdate, uid: str = Depends(get_current_user_uid)):
    user_profile_ref = db.collection('user_profiles').document(uid)
    current_profile_doc = await user_profile_ref.get()
    current_profile_data = current_profile_doc.to_dict() if current_profile_doc.exists else {}

    updated_data = profile_update.dict(exclude_unset=True)
    current_profile_data.update(updated_data)

    # Automatically set profile_status to complete if basic fields are filled
    if all(field in current_profile_data and current_profile_data[field] is not None
           for field in ["age", "gender", "seeking_gender", "hobbies", "bio", "height_cm", "pronouns"]):
        current_profile_data["profile_status"] = "complete"
    else:
        current_profile_data["profile_status"] = "incomplete"

    await user_profile_ref.set(current_profile_data)
    return UserProfile(**current_profile_data)

