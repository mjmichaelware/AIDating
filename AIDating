@app.get("/matches", response_model=List[Match])
async def get_matches(uid: str = Depends(get_current_user_uid)):
    current_user_profile_doc = await db.collection('user_profiles').document(uid).get()
    if not current_user_profile_doc.exists or current_user_profile_doc.to_dict().get("profile_status") != "complete":
        raise HTTPException(status.HTTP_400_BAD_REQUEST, detail="Profile incomplete. Please fill out questionnaire.")

    current_user_profile = UserProfile(**current_user_profile_doc.to_dict())
    
    # Fetch all profiles
    all_profiles_docs = await db.collection('user_profiles').where("profile_status", "==", "complete").get()
    potential_matches = []

    for doc in all_profiles_docs:
        if doc.id == uid: continue
        
        other_user_profile = UserProfile(**doc.to_dict())

        # Basic Matchmaking Logic:
        # 1. Gender preference
        # 2. Age within 5 years
        # 3. Min 1 common hobby
        # 4. Exclude users who have declined this user too many times recently (simplified)

        match_score = 0
        if current_user_profile.seeking_gender and other_user_profile.gender:
            if current_user_profile.seeking_gender.name == other_user_profile.gender.name:
                match_score += 1 # Gender match

        if current_user_profile.age and other_user_profile.age:
            if abs(current_user_profile.age - other_user_profile.age) <= 5:
                match_score += 1 # Age proximity

        common_hobbies_list = []
        if current_user_profile.hobbies and other_user_profile.hobbies:
            common_hobbies_list = list(set(current_user_profile.hobbies) & set(other_user_profile.hobbies))
            if len(common_hobbies_list) > 0:
                match_score += 1 # Has common hobbies

        if match_score >= 2: # Simple threshold for a "match"
            potential_matches.append(Match(
                uid=other_user_profile.uid,
                username=other_user_profile.username,
                age=other_user_profile.age or 0,
                gender=other_user_profile.gender.name if other_user_profile.gender else "Unknown",
                bio=other_user_profile.bio,
                common_hobbies=common_hobbies_list
            ))
    
    # Sort by match score (descending) then shuffle the top ones
    potential_matches.sort(key=lambda m: m.common_hobbies, reverse=True) # Simple sort
    random.shuffle(potential_matches)
    
    return potential_matches[:5] # Return top 5 matches (randomized after initial sort)

@app.post("/matches/{match_uid}/decline")
async def decline_match(match_uid: str, uid: str = Depends(get_current_user_uid)):
    # In a real app, you'd record this decline in a `user_declines` subcollection
    # or a dedicated system, and apply penalty logic.
    user_profile_ref = db.collection('user_profiles').document(uid)
    user_profile_doc = await user_profile_ref.get()

    if not user_profile_doc.exists:
        raise HTTPException(status.HTTP_404_NOT_FOUND, detail="Your profile does not exist.")

    current_decline_count = user_profile_doc.to_dict().get("date_decline_count", 0)
    current_decline_count += 1

    # Simple penalty logic: 3 declines in a row (simplified as total count)
    if current_decline_count >= 3:
        # Penalize: user cannot get new matches for a period (e.g., 24 hours)
        # Or you might temporarily disable matching for them.
        # For demo, just reset count and log.
        user_profile_ref.update({"date_decline_count": 0, "matching_disabled_until": firestore.SERVER_TIMESTAMP})
        raise HTTPException(status.HTTP_403_FORBIDDEN, detail="You have declined too many dates. Matching disabled temporarily.")
    else:
        await user_profile_ref.update({"date_decline_count": current_decline_count})

    return {"message": f"Match {match_uid} declined. Decline count: {current_decline_count}"}

