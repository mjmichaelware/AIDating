class ApiService {
  static const String baseUrl = 'http://127.0.0.1:8000';
  final String? _idToken; ApiService(this._idToken);
  Map<String, String> _getHeaders({bool jsonContent = true}) {
    final Map<String, String> headers = {}; if (jsonContent) headers['Content-Type'] = 'application/json';
    if (_idToken != null) headers['Authorization'] = 'Bearer $_idToken'; return headers;
  }
  Future<UserProfile?> getUserProfile() async {
    final url = Uri.parse('$baseUrl/users/me/profile'); try { final response = await http.get(url, headers: _getHeaders());
      if (response.statusCode == 200) return UserProfile.fromJson(json.decode(response.body));
      if (response.statusCode == 404) return null; throw Exception('Failed to load profile: ${response.statusCode} ${response.body}');
    } catch (e) { print('Error fetching profile: $e'); return null; }}
  Future<UserProfile> updateProfile(Map<String, dynamic> d) async {
    final url = Uri.parse('$baseUrl/users/me/profile'); final response = await http.put(url, headers: _getHeaders(), body: json.encode(d),);
    if (response.statusCode == 200) return UserProfile.fromJson(json.decode(response.body)); throw Exception('Failed to update profile: ${response.body}');}
  Future<UserProfile> submitQuestionnaire(Map<String, dynamic> d) async {
    final url = Uri.parse('$baseUrl/users/me/questionnaire'); final response = await http.post(url, headers: _getHeaders(), body: json.encode(d),);
    if (response.statusCode == 200) return UserProfile.fromJson(json.decode(response.body)); throw Exception('Failed to submit questionnaire: ${response.body}');}
  Future<List<Match>> getMatches() async {
    final url = Uri.parse('$baseUrl/matches'); try { final response = await http.get(url, headers: _getHeaders());
      if (response.statusCode == 200) { final List<dynamic> mj = json.decode(response.body); return mj.map((j) => Match.fromJson(j)).toList(); }
      if (response.statusCode == 400 || response.statusCode == 403) throw Exception(json.decode(response.body)['detail']);
      throw Exception('Failed to load matches: ${response.statusCode} ${response.body}');
    } catch (e) { print('Error fetching matches: $e'); rethrow; }}
  Future<Map<String, dynamic>> declineMatch(String matchUid) async {
    final url = Uri.parse('$baseUrl/matches/$matchUid/decline'); final response = await http.post(url, headers: _getHeaders());
    if (response.statusCode == 200) return json.decode(response.body); throw Exception('Failed to decline: ${response.body}');}
  Future<Map<String, dynamic>> acceptMatch(String matchUid) async {
    final url = Uri.parse('$baseUrl/matches/$matchUid/accept'); final response = await http.post(url, headers: _getHeaders());
    if (response.statusCode == 200) return json.decode(response.body); throw Exception('Failed to accept: ${response.body}');}
  Future<Map<String, dynamic>> registerBackend(String username, String email, String password) async {
    final url = Uri.parse('$baseUrl/register'); final response = await http.post(url, headers: _getHeaders(), body: json.encode({'username': username, 'email': email, 'password': password}),);
    if (response.statusCode == 200 || response.statusCode == 409) return json.decode(response.body); throw Exception('Backend reg failed: ${response.body}');}
  Future<Map<String, dynamic>> loginBackend(String email, String password) async {
    final url = Uri.parse('$baseUrl/login'); final response = await http.post(url, headers: _getHeaders(), body: json.encode({'email': email, 'password': password}),);
    if (response.statusCode == 200) return json.decode(response.body); throw Exception('Backend login failed: ${response.body}');}
}

class AuthService with ChangeNotifier {
  final FirebaseAuth _auth = FirebaseAuth.instance; User? _user; User? get user => _user;
  AuthService() { _auth.authStateChanges().listen((User? fu) { _user = fu; notifyListeners(); }); }
  Future<UserCredential?> signUp(String email, String password) async {
    try { UserCredential uc = await _auth.createUserWithEmailAndPassword(email: email, password: password); print("Reg: ${uc.user?.email}"); return uc; }
    on FirebaseAuthException catch (e) { throw Exception(_authExceptionMessage(e)); } catch (e) { throw Exception('Signup failed.'); }}
  Future<UserCredential?> signIn(String email, String password) async {
    try { UserCredential uc = await _auth.signInWithEmailAndPassword(email: email, password: password); print("Sign: ${uc.user?.email}"); return uc; }
    on FirebaseAuthException catch (e) { throw Exception(_authExceptionMessage(e)); } catch (e) { throw Exception('Signin failed.'); }}
  Future<void> signOut() async { try { await _auth.signOut(); print("Signed out."); } catch (e) { throw Exception('Signout failed.'); }}
  Future<String?> getIdToken() async { return await _user?.getIdToken(); }
  String _authExceptionMessage(FirebaseAuthException e) {
    switch (e.code) {
      case 'weak-password': return 'Weak password.'; case 'email-already-in-use': return 'Email in use.';
      case 'invalid-email': return 'Invalid email.'; case 'user-not-found': return 'No user found.';
      case 'wrong-password': return 'Wrong password.'; case 'user-disabled': return 'User disabled.';
      default: return 'Auth error.';
    }
  }
}

