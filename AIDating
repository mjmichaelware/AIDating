# --- Helper Function: Decorator for Protected API Routes (using JWTs) ---
# This function acts as a "guard" for API endpoints that require a user to be logged in.
def token_required(f):
    @wraps(f) # Preserves original function metadata
    def decorated(*args, **kwargs):
        token = None
        # JWT is typically sent in the Authorization header: "Bearer <token>"
        if 'Authorization' in request.headers:
            try:
                token = request.headers['Authorization'].split(" ")[1]
            except IndexError:
                return jsonify({'message': 'Token format is "Bearer <token>"'}), 401

        if not token:
            return jsonify({'message': 'Token is missing!'}), 401

        try:
            # Decode the token using your secret key. This also verifies expiration and signature.
            data = jwt.decode(token, JWT_SECRET_KEY, algorithms=['HS256'])
            # You can retrieve user data from the token payload, or fetch full profile from Firestore if needed
            current_user_id = data['user_id']
            current_user_display_name = data.get('display_name', 'User') # Get display name from token
            current_user_role = data.get('role', 'standard') # Assume 'standard' if no role in token

        except jwt.ExpiredSignatureError:
            return jsonify({'message': 'Token has expired'}), 401
        except jwt.InvalidTokenError:
            return jsonify({'message': 'Token is invalid'}), 401
        except Exception as e:
            return jsonify({'message': 'Could not process token', 'error': str(e)}), 500

        # Pass decoded user info to the actual API route function
        return f(current_user_id, current_user_display_name, current_user_role, *args, **kwargs)
    return decorated

# Need to import functools for @wraps in the decorator
