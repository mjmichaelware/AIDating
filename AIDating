async def create_dummy_users_and_profiles_on_startup():
    """Ensures predefined dummy users and their profiles exist in Firebase."""
    print("Startup: Checking/creating dummy users and profiles...")
    users_collection_ref = db.collection('user_profiles')

    for profile_data_template in PREDEFINED_DUMMY_PROFILES:
        try:
            user_in_auth = None
            try:
                user_in_auth = auth.get_user_by_email(profile_data_template["email"])
            except auth.UserNotFoundError:
                pass

            uid = user_in_auth.uid if user_in_auth else None

            if not uid:
                new_firebase_user = auth.create_user(
                    email=profile_data_template["email"],
                    password=profile_data_template["password"],
                    display_name=profile_data_template["username"]
                )
                uid = new_firebase_user.uid

            profile_doc_ref = users_collection_ref.document(uid)
            profile_doc = await profile_doc_ref.get()

            if not profile_doc.exists:
                profile_to_save = profile_data_template.copy()
                profile_to_save['uid'] = uid
                profile_to_save.pop('password', None)
                profile_to_save['profile_status'] = "complete" # Mark as complete for dummy users
                await profile_doc_ref.set(profile_to_save)
        except Exception as e:
            print(f"Error during dummy user setup for {profile_data_template['email']}: {e}")

@app.on_event("startup")
async def on_startup():
    await create_dummy_users_and_profiles_on_startup()

# --- Dependency for current user UID (authenticates requests) ---
async def get_current_user_uid(id_token: str = Depends(oauth2_scheme)):
    try:
        decoded_token = auth.verify_id_token(id_token)
        uid = decoded_token['uid']
        return uid
    except Exception as e:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail=f"Invalid authentication credentials: {e}",
            headers={"WWW-Authenticate": "Bearer"},
        )

